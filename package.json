{
  "name": "horizon-ai",
  "version": "1.0.0-genesis",
  "description": "Horizon Genesis — desktop AI agent with personas, plugins, workflows, and computer use. Local-first, bring-your-own-keys.",
  "author": "Ernest Kostevich",
  "license": "MIT",
  "homepage": "https://horizonaai.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ErnestKostevich/horizon-genesis.git"
  },
  "bugs": {
    "url": "https://github.com/ErnestKostevich/horizon-genesis/issues"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:universal": "electron-builder --mac --universal"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.horizonai.app",
    "productName": "Horizon AI",
    "asar": true,
    "files": ["src/**/*", "assets/**/*", "builtin-plugins/**/*"],
    "directories": { "output": "dist" },
    "protocols": [
      { "name": "Horizon Plugin Installer", "schemes": ["horizon"] }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [{ "target": "dmg", "arch": ["x64","arm64"] }]
    },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false, "shortcutName": "Horizon AI" }
  }
}
