# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output — installers are uploaded to GitHub Releases, not committed
dist/
out/
build/
*.exe
*.dmg
*.deb
*.AppImage
*.snap
*.blockmap

# Environment & secrets — never commit
.env
.env.*
!.env.example
*.pem
*.p12
*.p8
*.mobileprovision
*.keystore

# Apple notarization / signing artifacts
*.provisionprofile
*.cer

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Electron runtime data
.cache/
electron-builder-cache/
.electron-gyp/

# Local marketplace data & debug
local-data/
debug.log
crash.log

# Generated license keys (don't leak into commits)
license-keys.txt
keys.json

# CI-generated build marker — created by .github/workflows/release.yml only.
# Its presence is what unlocks the app; source clones must NEVER have it committed.
src/main/build-info.json
